{
  "rules": {
    "ambient_data": {
      ".read": true,
      ".write": "auth != null && auth.uid === 'REPLACE_WITH_DEVICE_UID'",
      "$ts": {
        ".validate": "newData.hasChildren(['temperatura','humedad','luz','timestamp'])"
      }
    },
    "motion_events": {
      ".read": true,
      ".write": "auth != null && auth.uid === 'REPLACE_WITH_DEVICE_UID'",
      "$ts": {
        ".validate": "newData.hasChildren(['detectado'])"
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
